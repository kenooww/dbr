# Copy this file to .env and fill in your own values

# MongoDB connection string (MongoDB Atlas or local MongoDB)
# Local example:  mongodb://127.0.0.1:27017/amihan-cove
# Atlas example:  mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/amihan-cove
MONGODB_URI=mongodb+srv://dbr:dbr2026@cluster0.ls7dsr7.mongodb.net/amihan-cove?appName=Cluster0

# Port the server runs on
PORT=5000

# Secret used to sign admin login tokens - change this to a long random string
JWT_SECRET="4086d4130e9ca99d6734fab9dedf73550e3e51512bfadb9ac437eb82e9a08161"

# Default admin account created by "npm run seed"
ADMIN_EMAIL=admin@amihancove.com
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Resort Admin

# Cloudinary - used to store room photos (works on serverless hosts like Vercel,
# which don't allow saving uploaded files to local disk)
# Get these from https://cloudinary.com/console after creating a free account
CLOUDINARY_CLOUD_NAME=dumaluan
CLOUDINARY_API_KEY=784865337697169
CLOUDINARY_API_SECRET=tglkrwEF7icFU6Z1iJOOd8cMUkY